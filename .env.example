NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Firebase Configuration
# 값은 GoogleService-Info.plist 또는 Firebase Console에서 확인
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# 웹 푸시 알림 사용 시에만 필요 (없으면 웹에서 FCM 등록 스킵)
# Firebase Console > 프로젝트 설정 > Cloud Messaging > 웹 푸시 인증서(VAPID 키)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# OAuth 진단: 앱 로그인 화면에 redirectTo/isNative/platform 표시 (값: true 또는 1)
# NEXT_PUBLIC_OAUTH_DEBUG=true

# 앱 빌드 전용 (build:app 스크립트에서 필수 검증)
# 운영 배포 API URL (예: https://api.example.com)
NEXT_PUBLIC_API_URL=

# App Store ID (숫자, App Store Connect의 앱 ID)
# 미설정 시 업데이트 권고 팝업이 노출되지 않음 (kill-switch)
NEXT_PUBLIC_APP_STORE_ID=
